COMPOSE_PROJECT_NAME=ran-feed

# App images
FRONT_API_IMAGE=ran-feed-front-api:dev
CONTENT_RPC_IMAGE=ran-feed-content-rpc:dev
INTERACTION_RPC_IMAGE=ran-feed-interaction-rpc:dev
USER_RPC_IMAGE=ran-feed-user-rpc:dev
COUNT_RPC_IMAGE=ran-feed-count-rpc:dev

# App runtime
LOG_PATH=/var/log/ran-feed
OTEL_ENDPOINT=otel-collector:4317
MYSQL_HOST=mysql
MYSQL_APP_USER=ran_feed
MYSQL_APP_PASSWORD=123456
REDIS_HOST=redis
REDIS_PASSWORD=
ETCD_HOST=etcd
KAFKA_BROKERS=kafka:9092
XXL_JOB_ADMIN_ADDR=http://xxl-job-admin:8080/xxl-job-admin
XXL_EXECUTOR_ADDRESS=content-rpc:5005
XXL_EXECUTOR_IP=content-rpc
XXL_EXECUTOR_PORT=5005
XXL_JOB_ACCESS_TOKEN=default_token
PROM_HOST=0.0.0.0

# App ports
FRONT_API_PORT=5000
CONTENT_RPC_PORT=5001
INTERACTION_RPC_PORT=5002
USER_RPC_PORT=5003
COUNT_RPC_PORT=5004
XXL_JOB_EXECUTOR_PORT=5005

# Nginx
NGINX_IMAGE=nginx:latest
NGINX_HTTP_PORT=80

# Frontend runtime config
# Empty = use same-origin (recommended). Example for local: http://127.0.0.1:80
API_BASE_URL=

# Etcd
ETCD_IMAGE=bitnami/etcd:latest
ETCD_CLIENT_PORT=2379
ETCD_PEER_PORT=2380

# Redis
REDIS_IMAGE=redis:7.2
REDIS_PORT=6379

# MySQL
MYSQL_IMAGE=mysql:8.0
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=ran-feed
MYSQL_USER=ran_feed
MYSQL_PASSWORD=123456

# Kafka (KRaft)
KAFKA_IMAGE=bitnami/kafka:3.5.2
KAFKA_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_CLUSTER_ID=pwc-TOq3SkSuLvBA8dxkRQ

# XXL-JOB
XXL_JOB_IMAGE=xuxueli/xxl-job-admin:2.4.0
XXL_JOB_PORT=8081

# Canal
CANAL_IMAGE=canal/canal-server:latest
CANAL_PORT=11111

# OpenTelemetry Collector
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector:0.100.0
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318

# Jaeger
JAEGER_IMAGE=jaegertracing/all-in-one:1.54
JAEGER_UI_PORT=16686

# Prometheus
PROMETHEUS_IMAGE=prom/prometheus:v2.51.2
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_IMAGE=grafana/grafana:11.0.1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Elasticsearch / Logstash / Kibana / Filebeat
ELASTIC_IMAGE=elastic/elasticsearch:8.12.2
KIBANA_IMAGE=docker.elastic.co/kibana/kibana:8.12.2
LOGSTASH_IMAGE=elastic/logstash:8.12.2
FILEBEAT_IMAGE=docker.elastic.co/beats/filebeat:8.12.2
ELASTIC_PORT=9200
KIBANA_PORT=5601
LOGSTASH_PORT=5044

# OSS
OSS_PROVIDER=
OSS_REGION=
OSS_BUCKET_NAME=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ROLE_ARN=
